{
  "name": "@werehere/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/app.ts"
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --config wrangler.preview.jsonc --outdir dist/api && wrangler deploy --dry-run --config wrangler.reconciler.preview.jsonc --outdir dist/reconciler",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:worker": "bash test/run-worker-auth-smoke.sh"
  },
  "dependencies": {
    "@werehere/contracts": "workspace:*",
    "@werehere/db": "workspace:*",
    "hono": "4.12.25",
    "jose": "6.2.3",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "wrangler": "4.111.0"
  }
}
