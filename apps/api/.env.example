# API local/preview configuration names only.
# Do not commit real secrets in this file.

# local Docker ZITADEL default endpoint
ZITADEL_API_ENDPOINT=http://localhost:8080

# preview/production standard service account credential.
# Store the real value only in approved secret storage.
ZITADEL_SERVICE_ACCOUNT_JSON=

# local temporary verification only. Prefer ZITADEL_SERVICE_ACCOUNT_JSON for preview/production.
ZITADEL_ACCESS_TOKEN=

# ZITADEL organization id for user registration flows.
ZITADEL_ORG_ID=
