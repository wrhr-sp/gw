{
  "name": "@gw/web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "../../scripts/gw-web-build-locked.sh next build",
    "build:cf": "../../scripts/gw-web-build-locked.sh opennextjs-cloudflare build",
    "preview:cf": "../../scripts/gw-web-build-locked.sh opennextjs-cloudflare build && wrangler dev",
    "deploy:cf": "pnpm deploy:cf:production",
    "deploy:cf:preview": "../../scripts/gw-web-build-locked.sh opennextjs-cloudflare build && opennextjs-cloudflare deploy --env preview",
    "deploy:cf:production": "../../scripts/gw-web-build-locked.sh opennextjs-cloudflare build && opennextjs-cloudflare deploy --env production",
    "typecheck": "../../scripts/gw-web-build-locked.sh tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@gw/shared": "workspace:*",
    "@tinymce/tinymce-react": "^6.3.0",
    "next": "^15.5.19",
    "pretendard": "^1.3.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tinymce": "^8.6.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.98.0"
  }
}
