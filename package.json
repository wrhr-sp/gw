{
  "name": "werehere-hotel-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:boundaries": "node scripts/test-import-boundaries.mjs",
    "test:integration": "pnpm --filter @werehere/db test:integration",
    "test:mutation-verifier": "node scripts/test-file-mutation-verifier.mjs",
    "test:visual": "pnpm --filter @werehere/web test:visual",
    "test:visual:update": "pnpm --filter @werehere/web test:visual:update",
    "verify:mutations": "node scripts/verify-file-mutations.mjs",
    "check": "pnpm run typecheck && pnpm run test && pnpm run test:boundaries && pnpm run test:mutation-verifier"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "9.39.1",
    "@types/node": "24.3.0",
    "eslint": "9.39.1",
    "eslint-config-next": "15.5.20",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.1",
    "vitest": "3.2.4"
  }
}
